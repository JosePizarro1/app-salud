      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Inter', sans-serif;\n    color: white;\n    background: #0f172a;\n    overflow-x: hidden;\n  }\n\n  .mesh-gradient {\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    z-index: -1;\n    background-color: #0f172a;\n    background-image: \n      radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), \n      radial-gradient(at 50% 0%, hsla(225,39%,30%,1) 0, transparent 50%), \n      radial-gradient(at 100% 0%, hsla(339,49%,30%,1) 0, transparent 50%), \n      radial-gradient(at 0% 100%, hsla(225,39%,30%,1) 0, transparent 50%), \n      radial-gradient(at 100% 100%, hsla(339,49%,30%,1) 0, transparent 50%);\n  }\n\n  .font-playfair {\n    font-family: 'Playfair Display', serif;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .teardrop-container {\n    position: relative;\n    width: 120px;\n    height: 120px;\n    margin: 0 auto;\n    filter: drop-shadow(0 0 15px rgba(167, 139, 250, 0.4));\n  }\n\n  .teardrop-shape {\n    width: 100%;\n    height: 100%;\n    background: rgba(255, 255, 255, 0.05);\n    clip-path: path('M60 0 C60 0 0 60 0 90 C0 106.569 13.4315 120 30 120 L90 120 C106.569 120 120 106.569 120 90 C120 60 60 0 60 0 Z');\n    position: relative;\n    overflow: hidden;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n  }\n\n  .liquid-fill {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 100%;\n    height: 60%; /* This would be dynamic based on progress */\n    background: linear-gradient(180deg, #a78bfa 0%, #7c3aed 100%);\n    animation: wave 4s ease-in-out infinite;\n    transform-origin: bottom;\n  }\n\n  @keyframes wave {\n    0%, 100% { transform: scaleY(1); }\n    50% { transform: scaleY(1.05); }\n  }\n\n  .watermark-number {\n    position: absolute;\n    top: -10px;\n    right: 10px;\n    font-size: 64px;\n    font-weight: 900;\n    opacity: 0.05;\n    pointer-events: none;\n    font-family: 'Playfair Display', serif;\n    font-style: italic;\n  }\n\n  .staggered-card:nth-child(even) {\n    transform: translateY(20px);\n  }\n\n  .masonry-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px;\n  }\n</style>\n\n<div class=\"mesh-gradient\" data-kid=\"1\"></div>\n\n<div class=\"min-h-screen px-6 py-8 relative\" data-kid=\"2\">\n  \n  <header class=\"flex items-center justify-between mb-10\" data-kid=\"3\">\n    <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-white/80 hover:text-white transition-colors\" data-kid=\"4\">\n      <i class=\"ti ti-chevron-left text-xl\" data-kid=\"5\"></i>\n    </button>\n    <h1 class=\"font-playfair text-xl font-medium tracking-wide\" data-kid=\"6\">Sleep Care</h1>\n    <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-white/80\" data-kid=\"7\">\n      <i class=\"ti ti-dots text-xl\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  \n  <section class=\"text-center mb-12\" data-kid=\"9\">\n    <div class=\"teardrop-container mb-6\" data-kid=\"10\">\n      <div class=\"teardrop-shape\" data-kid=\"11\">\n        <div class=\"liquid-fill\" data-kid=\"12\"></div>\n      </div>\n      <div class=\"absolute inset-0 flex items-center justify-center mt-6\" data-kid=\"13\">\n        <span class=\"font-playfair text-3xl font-bold tracking-tighter\" data-kid=\"14\">60%</span>\n      </div>\n    </div>\n    <h2 class=\"font-playfair italic text-lg text-white/90 mb-2\" data-kid=\"15\">Tu descanso hoy</h2>\n    <p class=\"text-xs text-white/50 font-light tracking-widest uppercase\" data-kid=\"16\">Excelente trabajo, sigue así</p>\n  </section>\n\n  \n  <div class=\"flex items-center gap-3 mb-6\" data-kid=\"17\">\n    <div class=\"h-[1px] grow bg-white/10\" data-kid=\"18\"></div>\n    <span class=\"text-[10px] uppercase tracking-[0.2em] text-white/40 font-semibold\" data-kid=\"19\">Módulos de Lectura</span>\n    <div class=\"h-[1px] grow bg-white/10\" data-kid=\"20\"></div>\n  </div>\n\n  \n  <div class=\"masonry-grid mb-12\" data-kid=\"21\">\n    \n    <div class=\"staggered-card glass rounded-2xl p-5 relative overflow-hidden flex flex-col gap-4 aspect-[4/5] justify-between\" data-kid=\"22\">\n      <span class=\"watermark-number\" data-kid=\"23\">1</span>\n      <div class=\"w-8 h-8 rounded-lg bg-yellow-400/20 flex items-center justify-center\" data-kid=\"24\">\n        <i class=\"ti ti-moon-stars text-yellow-400 text-lg\" data-kid=\"25\"></i>\n      </div>\n      <h3 class=\"font-playfair text-sm leading-tight text-white/90\" data-kid=\"26\">¿Qué es el cuidado del sueño?</h3>\n      <div class=\"flex items-center justify-between mt-auto\" data-kid=\"27\">\n        <span class=\"text-[9px] text-white/40 uppercase tracking-widest\" data-kid=\"28\">Leído</span>\n        <i class=\"ti ti-circle-check-filled text-emerald-400 text-xs\" data-kid=\"29\"></i>\n      </div>\n    </div>\n\n    \n    <div class=\"staggered-card glass rounded-2xl p-5 relative overflow-hidden flex flex-col gap-4 aspect-[4/5] justify-between\" data-kid=\"30\">\n      <span class=\"watermark-number\" data-kid=\"31\">2</span>\n      <div class=\"w-8 h-8 rounded-lg bg-red-400/20 flex items-center justify-center\" data-kid=\"32\">\n        <i class=\"ti ti-heart text-red-400 text-lg\" data-kid=\"33\"></i>\n      </div>\n      <h3 class=\"font-playfair text-sm leading-tight text-white/90\" data-kid=\"34\">Beneficios de cuidar el descanso</h3>\n      <div class=\"flex items-center justify-between mt-auto\" data-kid=\"35\">\n        <span class=\"text-[9px] text-white/40 uppercase tracking-widest\" data-kid=\"36\">Leído</span>\n        <i class=\"ti ti-circle-check-filled text-emerald-400 text-xs\" data-kid=\"37\"></i>\n      </div>\n    </div>\n\n    \n    <div class=\"staggered-card glass rounded-2xl p-5 relative overflow-hidden flex flex-col gap-4 aspect-[4/5] justify-between\" data-kid=\"38\">\n      <span class=\"watermark-number\" data-kid=\"39\">3</span>\n      <div class=\"w-8 h-8 rounded-lg bg-amber-400/20 flex items-center justify-center\" data-kid=\"40\">\n        <i class=\"ti ti-book-open text-amber-400 text-lg\" data-kid=\"41\"></i>\n      </div>\n      <h3 class=\"font-playfair text-sm leading-tight text-white/90\" data-kid=\"42\">¿Qué incluye el cuidado?</h3>\n      <div class=\"flex items-center justify-between mt-auto text-white/30\" data-kid=\"43\">\n        <span class=\"text-[9px] uppercase tracking-widest\" data-kid=\"44\">4 min</span>\n        <i class=\"ti ti-chevron-right text-xs\" data-kid=\"45\"></i>\n      </div>\n    </div>\n\n    \n    <div class=\"staggered-card glass rounded-2xl p-5 relative overflow-hidden flex flex-col gap-4 aspect-[4/5] justify-between\" data-kid=\"46\">\n      <span class=\"watermark-number\" data-kid=\"47\">4</span>\n      <div class=\"w-8 h-8 rounded-lg bg-orange-400/20 flex items-center justify-center\" data-kid=\"48\">\n        <i class=\"ti ti-alert-triangle text-orange-400 text-lg\" data-kid=\"49\"></i>\n      </div>\n      <h3 class=\"font-playfair text-sm leading-tight text-white/90\" data-kid=\"50\">Riesgos de no cuidarlo</h3>\n      <div class=\"flex items-center justify-between mt-auto text-white/30\" data-kid=\"51\">\n        <span class=\"text-[9px] uppercase tracking-widest\" data-kid=\"52\">6 min</span>\n        <i class=\"ti ti-chevron-right text-xs\" data-kid=\"53\"></i>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-8 mb-4 glass rounded-3xl overflow-hidden relative min-h-[140px] flex items-center group cursor-pointer border border-white/5\" data-kid=\"54\">\n    \n    <div class=\"absolute inset-0 opacity-10 pointer-events-none\" style=\"background: url('https://images.unsplash.com/photo-1595671061520-903acbb49900?auto=format&w=800&q=80&fit=crop'); background-size: cover;\" data-kid=\"55\"></div>\n    \n    <div class=\"relative z-10 p-6 flex items-center gap-6\" data-kid=\"56\">\n      <div class=\"w-20 h-20 rounded-2xl overflow-hidden flex-shrink-0 shadow-2xl rotate-[-3deg] group-hover:rotate-0 transition-transform duration-500\" data-kid=\"57\">\n        <img src=\"https://images.pexels.com/photos/15419005/pexels-photo-15419005.jpeg?auto=compress&cs=tinysrgb&w=200&q=80\" alt=\"Marble Statue with mask\" class=\"w-full h-full object-cover grayscale brightness-110\" loading=\"lazy\" decoding=\"async\" data-kid=\"58\">\n      </div>\n      <div class=\"flex flex-col\" data-kid=\"59\">\n        <h4 class=\"font-playfair italic text-lg leading-tight mb-1\" data-kid=\"60\">¡Sigue aprendiendo!</h4>\n        <p class=\"text-xs text-white/60 leading-relaxed max-w-[160px]\" data-kid=\"61\">Cada pequeño cambio mejora tu descanso eterno.</p>\n      </div>\n    </div>\n    \n    \n    <div class=\"absolute top-4 right-6 text-white/20 animate-pulse\" data-kid=\"62\">\n      <i class=\"ti ti-sparkles text-xl\" data-kid=\"63\"></i>\n    </div>\n  </div>\n\n  \n  <div class=\"fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] max-w-[340px] h-16 glass rounded-full flex items-center justify-around px-2 z-50\" data-kid=\"64\">\n    <button class=\"w-12 h-12 rounded-full flex items-center justify-center text-violet-400 bg-violet-400/10\" data-kid=\"65\">\n      <i class=\"ti ti-smart-home text-2xl\" data-kid=\"66\"></i>\n    </button>\n    <button class=\"w-12 h-12 rounded-full flex items-center justify-center text-white/40\" data-kid=\"67\">\n      <i class=\"ti ti-moon text-2xl\" data-kid=\"68\"></i>\n    </button>\n    <button class=\"w-12 h-12 rounded-full flex items-center justify-center text-white/40\" data-kid=\"69\">\n      <i class=\"ti ti-notes text-2xl\" data-kid=\"70\"></i>\n    </button>\n    <button class=\"w-12 h-12 rounded-full flex items-center justify-center text-white/40\" data-kid=\"71\">\n      <i class=\"ti ti-user text-2xl\" data-kid=\"72\"></i>\n    </button>\n  </div>\n</div>",
