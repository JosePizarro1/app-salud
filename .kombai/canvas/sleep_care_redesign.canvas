      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Quicksand', sans-serif;\n    background: #020617;\n    margin: 0;\n    color: white;\n    overflow-x: hidden;\n  }\n\n  .night-gradient {\n    background: radial-gradient(circle at top right, #1e293b 0%, #020617 60%);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .leaf-shape {\n    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;\n  }\n\n  .glowing-petal {\n    filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.6));\n  }\n\n  .sparkle {\n    position: absolute;\n    width: 4px;\n    height: 4px;\n    background: white;\n    border-radius: 50%;\n    filter: blur(1px);\n    opacity: 0.6;\n  }\n\n  /* Vine Path Styling */\n  .vine-line {\n    stroke-dasharray: 8 8;\n  }\n</style>\n\n<div class=\"night-gradient min-h-screen relative pb-20\" data-kid=\"1\">\n  \n  <div class=\"absolute top-0 left-0 w-full h-[400px] overflow-hidden opacity-20 pointer-events-none\" data-kid=\"2\">\n    <video src=\"https://videos.pexels.com/video-files/30892710/13207931_640_360_24fps.mp4\" poster=\"https://images.pexels.com/videos/30892710/flower-flowers-grow-growing-30892710.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover grayscale\" data-kid=\"3\"></video>\n    <div class=\"absolute inset-0 bg-gradient-to-b from-transparent to-[#020617]\" data-kid=\"4\"></div>\n  </div>\n\n  \n  <header class=\"relative z-10 px-6 pt-12 flex items-center justify-between\" data-kid=\"5\">\n    <button class=\"w-10 h-10 leaf-shape glass-card flex items-center justify-center text-white/80 hover:text-white transition-colors\" data-kid=\"6\">\n      <i class=\"ti ti-chevron-left text-xl\" data-kid=\"7\"></i>\n    </button>\n    <h1 class=\"text-xl font-bold tracking-tight text-white/90\" data-kid=\"8\">Cuidado del Sueño</h1>\n    <div class=\"w-10\" data-kid=\"9\"></div> \n  </header>\n\n  \n  <section class=\"relative z-10 flex flex-col items-center pt-8 pb-12 overflow-hidden\" data-kid=\"10\">\n    <div class=\"relative w-64 h-64 flex items-center justify-center\" data-kid=\"11\">\n      \n      <div class=\"sparkle top-10 left-20 animate-pulse\" data-kid=\"12\"></div>\n      <div class=\"sparkle bottom-10 right-20 animate-pulse\" style=\"animation-delay: 1s;\" data-kid=\"13\"></div>\n      <div class=\"sparkle top-40 right-10 animate-pulse\" style=\"animation-delay: 2s;\" data-kid=\"14\"></div>\n\n      \n      <svg viewBox=\"0 0 100 100\" class=\"w-full h-full transform transition-transform duration-1000\" data-kid=\"15\">\n        \n        <g class=\"glowing-petal text-[#10B981]\" data-kid=\"16\">\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" fill-opacity=\"0.2\" transform=\"rotate(0 50 50)\" data-kid=\"17\"></ellipse>\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" fill-opacity=\"0.2\" transform=\"rotate(51.4 50 50)\" data-kid=\"18\"></ellipse>\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" fill-opacity=\"0.2\" transform=\"rotate(102.8 50 50)\" data-kid=\"19\"></ellipse>\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" fill-opacity=\"0.2\" transform=\"rotate(154.2 50 50)\" data-kid=\"20\"></ellipse>\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" fill-opacity=\"0.2\" transform=\"rotate(205.6 50 50)\" data-kid=\"21\"></ellipse>\n        </g>\n        \n        <g class=\"text-white/10\" data-kid=\"22\">\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" transform=\"rotate(257 50 50)\" data-kid=\"23\"></ellipse>\n          <ellipse cx=\"50\" cy=\"30\" rx=\"10\" ry=\"25\" fill=\"currentColor\" transform=\"rotate(308.4 50 50)\" data-kid=\"24\"></ellipse>\n        </g>\n        \n        \n        <circle cx=\"50\" cy=\"50\" r=\"22\" fill=\"#020617\" class=\"border border-white/10\" data-kid=\"25\"></circle>\n        <text x=\"50\" y=\"53\" text-anchor=\"middle\" font-size=\"12\" font-weight=\"bold\" fill=\"white\" data-kid=\"26\">71%</text>\n      </svg>\n    </div>\n    \n    <div class=\"text-center mt-4\" data-kid=\"27\">\n      <p class=\"text-white/80 font-medium\" data-kid=\"28\">Excelente trabajo</p>\n      <p class=\"text-xs text-white/40 mt-1\" data-kid=\"29\">¡Estás floreciendo en tu descanso!</p>\n    </div>\n  </section>\n\n  \n  <section class=\"relative px-6 z-10\" data-kid=\"30\">\n    <div class=\"flex items-center gap-2 mb-8\" data-kid=\"31\">\n      <div class=\"w-8 h-8 leaf-shape bg-[#10B981]/20 flex items-center justify-center\" data-kid=\"32\">\n        <i class=\"ti ti-leaf text-[#10B981]\" data-kid=\"33\"></i>\n      </div>\n      <h2 class=\"text-sm font-semibold uppercase tracking-wider text-white/50\" data-kid=\"34\">Tu Jardín del Conocimiento</h2>\n    </div>\n\n    <div class=\"relative pl-8\" data-kid=\"35\">\n      \n      <svg class=\"absolute left-0 top-0 h-full w-20 pointer-events-none\" preserveAspectRatio=\"none\" data-kid=\"36\">\n        <path d=\"M 10 0 Q 60 100 10 200 Q 60 300 10 400 Q 60 500 10 600\" fill=\"none\" stroke=\"rgba(16, 185, 129, 0.2)\" stroke-width=\"2\" class=\"vine-line\" data-kid=\"37\"></path>\n      </svg>\n\n      \n      <div class=\"space-y-6\" data-kid=\"38\">\n        \n        <div class=\"relative flex items-center group\" data-kid=\"39\">\n          <div class=\"absolute -left-10 w-4 h-4 rounded-full bg-[#10B981] shadow-[0_0_10px_rgba(16,185,129,0.8)] z-20\" data-kid=\"40\"></div>\n          <div class=\"leaf-shape glass-card p-4 w-full border-[#10B981]/40 transition-transform duration-300 group-hover:-translate-y-1\" data-kid=\"41\">\n            <div class=\"flex items-center gap-3\" data-kid=\"42\">\n              <div class=\"w-10 h-10 leaf-shape bg-[#1E1E38] flex items-center justify-center text-yellow-300\" data-kid=\"43\">\n                <i class=\"ti ti-moon-stars text-xl\" data-kid=\"44\"></i>\n              </div>\n              <div data-kid=\"45\">\n                <h3 class=\"text-sm font-bold text-white/90\" data-kid=\"46\">1. ¿Qué es el cuidado del sueño?</h3>\n                <div class=\"flex items-center gap-1 mt-1 text-[10px] text-[#10B981]\" data-kid=\"47\">\n                  <i class=\"ti ti-check text-xs\" data-kid=\"48\"></i>\n                  <span class=\"uppercase tracking-widest font-bold\" data-kid=\"49\">Completado</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"relative flex items-center group ml-4\" data-kid=\"50\">\n          <div class=\"absolute -left-14 w-4 h-4 rounded-full bg-[#10B981] shadow-[0_0_10px_rgba(16,185,129,0.8)] z-20\" data-kid=\"51\"></div>\n          <div class=\"leaf-shape glass-card p-4 w-full border-[#10B981]/40 transition-transform duration-300 group-hover:-translate-y-1\" data-kid=\"52\">\n            <div class=\"flex items-center gap-3\" data-kid=\"53\">\n              <div class=\"w-10 h-10 leaf-shape bg-rose-500/20 flex items-center justify-center text-rose-400\" data-kid=\"54\">\n                <i class=\"ti ti-heart text-xl\" data-kid=\"55\"></i>\n              </div>\n              <div data-kid=\"56\">\n                <h3 class=\"text-sm font-bold text-white/90\" data-kid=\"57\">2. Beneficios del descanso</h3>\n                <div class=\"flex items-center gap-1 mt-1 text-[10px] text-[#10B981]\" data-kid=\"58\">\n                  <i class=\"ti ti-check text-xs\" data-kid=\"59\"></i>\n                  <span class=\"uppercase tracking-widest font-bold\" data-kid=\"60\">Completado</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"relative flex items-center group\" data-kid=\"61\">\n          <div class=\"absolute -left-10 w-6 h-6 rounded-full bg-[#020617] border-2 border-[#FB7185] flex items-center justify-center z-20 animate-pulse\" data-kid=\"62\">\n            <div class=\"w-2 h-2 rounded-full bg-[#FB7185]\" data-kid=\"63\"></div>\n          </div>\n          <div class=\"leaf-shape bg-[#FB7185]/10 backdrop-blur-md p-5 w-full border border-[#FB7185]/30 ring-1 ring-[#FB7185]/20 shadow-[0_10px_25px_-5px_rgba(251,113,133,0.2)] transition-transform duration-300 group-hover:-translate-y-1\" data-kid=\"64\">\n            <div class=\"flex items-center gap-4\" data-kid=\"65\">\n              <div class=\"w-12 h-12 leaf-shape bg-[#FB7185] flex items-center justify-center text-white shadow-lg shadow-rose-900/40\" data-kid=\"66\">\n                <i class=\"ti ti-books text-2xl\" data-kid=\"67\"></i>\n              </div>\n              <div data-kid=\"68\">\n                <h3 class=\"text-base font-bold text-white\" data-kid=\"69\">3. Lo que incluye el cuidado</h3>\n                <p class=\"text-xs text-white/60 mt-1 italic\" data-kid=\"70\">Toca para comenzar lectura</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"relative flex items-center opacity-40 grayscale-[0.5]\" data-kid=\"71\">\n          <div class=\"absolute -left-10 w-4 h-4 rounded-full bg-white/20 z-20\" data-kid=\"72\"></div>\n          <div class=\"leaf-shape glass-card p-4 w-full\" data-kid=\"73\">\n            <div class=\"flex items-center gap-3\" data-kid=\"74\">\n              <div class=\"w-10 h-10 leaf-shape bg-white/10 flex items-center justify-center text-white/40\" data-kid=\"75\">\n                <i class=\"ti ti-alert-triangle text-xl\" data-kid=\"76\"></i>\n              </div>\n              <div data-kid=\"77\">\n                <h3 class=\"text-sm font-bold text-white/60\" data-kid=\"78\">4. Riesgos por falta de sueño</h3>\n                <div class=\"flex items-center gap-1 mt-1 text-[10px] text-white/30\" data-kid=\"79\">\n                  <i class=\"ti ti-lock text-xs\" data-kid=\"80\"></i>\n                  <span class=\"uppercase tracking-widest font-bold\" data-kid=\"81\">Bloqueado</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-6 mt-16\" data-kid=\"82\">\n    <div class=\"leaf-shape bg-gradient-to-br from-[#10B981]/10 to-[#FB7185]/10 backdrop-blur-xl p-6 border border-white/10 relative overflow-hidden group\" data-kid=\"83\">\n      \n      <div class=\"absolute -top-4 -right-4 w-20 h-20 bg-[#10B981]/10 rounded-full blur-2xl\" data-kid=\"84\"></div>\n      \n      <div class=\"flex items-center gap-6 relative z-10\" data-kid=\"85\">\n        <div class=\"relative\" data-kid=\"86\">\n          <div class=\"w-20 h-20 leaf-shape overflow-hidden border-2 border-[#10B981]/30\" data-kid=\"87\">\n            <img src=\"https://images.unsplash.com/photo-1712201649822-e22f8a8d7416?auto=format&w=200&q=80&fit=crop\" alt=\"Sleepy Monkey\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" data-kid=\"88\">\n          </div>\n          <div class=\"absolute -bottom-1 -right-1 bg-[#020617] p-1 rounded-full text-xs\" data-kid=\"89\">✨</div>\n        </div>\n        \n        <div class=\"flex-1\" data-kid=\"90\">\n          <h4 class=\"text-lg font-bold text-white/90\" data-kid=\"91\">¡Sigue creciendo!</h4>\n          <p class=\"text-sm text-white/50 mt-1 leading-tight\" data-kid=\"92\">Cada rama que recorres mejora tu descanso.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"fixed bottom-6 left-1/2 -translate-x-1/2 z-50\" data-kid=\"93\">\n    <div class=\"w-12 h-1 bg-white/10 rounded-full overflow-hidden\" data-kid=\"94\">\n      <div class=\"w-[71%] h-full bg-[#10B981] shadow-[0_0_10px_#10B981]\" data-kid=\"95\"></div>\n    </div>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"96\"></script>\n<script data-kid=\"97\">\n  // Soft animations for organic feel\n  gsap.to('.sparkle', {\n    y: '-=20',\n    opacity: 0.2,\n    duration: 'random(2, 4)',\n    repeat: -1,\n    yoyo: true,\n    stagger: 0.5,\n    ease: \"sine.inOut\"\n  });\n\n  gsap.to('.glowing-petal', {\n    filter: 'drop-shadow(0 0 15px rgba(16, 185, 129, 0.9))',\n    duration: 2,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n</script>",
