      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Space+Grotesk:wght@500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    background-color: #0F172A;\n    color: white;\n    font-family: 'Outfit', sans-serif;\n    margin: 0;\n    padding: 0;\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  .font-space {\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .neon-glow-lavender {\n    box-shadow: 0 0 15px rgba(167, 139, 250, 0.3);\n  }\n\n  .neon-glow-mint {\n    box-shadow: 0 0 15px rgba(45, 212, 191, 0.3);\n  }\n\n  .hud-ring {\n    animation: rotate 20s linear infinite;\n  }\n\n  @keyframes rotate {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n\n  .dashed-line {\n    background-image: linear-gradient(to bottom, #A78BFA 50%, transparent 50%);\n    background-size: 2px 10px;\n    background-repeat: repeat-y;\n  }\n\n  .timeline-dot {\n    background: radial-gradient(circle, #A78BFA 0%, transparent 70%);\n  }\n</style>\n\n<div class=\"relative w-full min-h-screen pb-32\" data-kid=\"1\">\n  \n  <div class=\"absolute top-0 -left-20 w-80 h-80 bg-purple-600/20 rounded-full blur-3xl pointer-events-none\" data-kid=\"2\"></div>\n  <div class=\"absolute top-40 -right-20 w-80 h-80 bg-cyan-600/10 rounded-full blur-3xl pointer-events-none\" data-kid=\"3\"></div>\n\n  \n  <header class=\"flex items-center px-6 pt-12 pb-6 relative z-10\" data-kid=\"4\">\n    <button class=\"w-10 h-10 glass rounded-full flex items-center justify-center text-white/80 hover:text-white transition-colors\" data-kid=\"5\">\n      <i class=\"ti ti-chevron-left text-lg\" data-kid=\"6\"></i>\n    </button>\n    <h1 class=\"ml-4 text-xl font-space font-bold tracking-tight\" data-kid=\"7\">CUIDADO DEL SUEÑO</h1>\n  </header>\n\n  \n  <section class=\"px-6 py-4 relative z-10\" data-kid=\"8\">\n    <div class=\"glass rounded-3xl p-8 relative overflow-hidden flex flex-col items-center\" data-kid=\"9\">\n      \n      <video src=\"https://videos.pexels.com/video-files/12973197/12973197-hd_1280_720_60fps.mp4\" poster=\"https://images.pexels.com/videos/12973197/abstract-alien-astrology-astronomy-12973197.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-20 pointer-events-none\" data-kid=\"10\"></video>\n      \n      \n      <div class=\"relative w-48 h-48 flex items-center justify-center\" data-kid=\"11\">\n        \n        <svg class=\"absolute inset-0 w-full h-full -rotate-90 opacity-20\" viewBox=\"0 0 100 100\" data-kid=\"12\">\n          <circle cx=\"50\" cy=\"50\" r=\"45\" fill=\"none\" stroke=\"white\" stroke-width=\"0.5\" data-kid=\"13\"></circle>\n        </svg>\n        \n        \n        <div class=\"absolute inset-0 hud-ring\" data-kid=\"14\">\n          <svg class=\"w-full h-full opacity-40\" viewBox=\"0 0 100 100\" data-kid=\"15\">\n            <path d=\"M50 5 A45 45 0 0 1 95 50\" fill=\"none\" stroke=\"#A78BFA\" stroke-width=\"2\" stroke-linecap=\"round\" data-kid=\"16\"></path>\n            <path d=\"M50 95 A45 45 0 0 1 5 50\" fill=\"none\" stroke=\"#2DD4BF\" stroke-width=\"2\" stroke-linecap=\"round\" data-kid=\"17\"></path>\n          </svg>\n        </div>\n\n        \n        <div class=\"text-center\" data-kid=\"18\">\n          <span class=\"block text-4xl font-space font-bold text-white drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]\" data-kid=\"19\">42%</span>\n          <span class=\"text-[10px] font-space tracking-widest text-white/50 uppercase\" data-kid=\"20\">Sync Level</span>\n        </div>\n\n        \n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/octogonal-eye.svg\" class=\"absolute -top-2 w-6 h-6 opacity-30 invert\" data-kid=\"21\">\n      </div>\n\n      <div class=\"mt-6 text-center\" data-kid=\"22\">\n        <h2 class=\"text-lg font-space font-semibold\" data-kid=\"23\">Tu progreso</h2>\n        <p class=\"text-xs text-white/60 mt-1\" data-kid=\"24\">Excelente trabajo, ¡sigue así!</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"px-6 py-8 relative z-10\" data-kid=\"25\">\n    <div class=\"flex items-center mb-6\" data-kid=\"26\">\n      <div class=\"w-1 h-4 bg-purple-500 rounded-full mr-3 neon-glow-lavender\" data-kid=\"27\"></div>\n      <h3 class=\"text-sm font-space font-bold tracking-widest text-white/40 uppercase\" data-kid=\"28\">A. NÓDULOS DE APRENDIZAJE</h3>\n    </div>\n\n    <div class=\"relative pl-8\" data-kid=\"29\">\n      \n      <div class=\"absolute left-3.5 top-2 bottom-0 w-[2px] dashed-line opacity-30\" data-kid=\"30\"></div>\n\n      \n      <div class=\"space-y-6\" data-kid=\"31\">\n        \n        <div class=\"relative\" data-kid=\"32\">\n          <div class=\"absolute -left-8 top-4 w-7 h-7 bg-[#0F172A] border border-mint-500 rounded-full flex items-center justify-center z-10 neon-glow-mint border-[#2DD4BF]\" data-kid=\"33\">\n            <i class=\"ti ti-check text-xs text-[#2DD4BF]\" data-kid=\"34\"></i>\n          </div>\n          <div class=\"glass rounded-2xl p-4 flex items-center border-[#2DD4BF]/30\" data-kid=\"35\">\n            <div class=\"w-10 h-10 bg-indigo-900/50 rounded-xl flex items-center justify-center mr-4\" data-kid=\"36\">\n              <i class=\"ti ti-moon text-indigo-300 text-lg\" data-kid=\"37\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"38\">\n              <span class=\"text-[10px] text-indigo-400 font-space font-bold uppercase\" data-kid=\"39\">01 DEFINICIÓN</span>\n              <h4 class=\"text-sm font-semibold text-white/90\" data-kid=\"40\">¿Qué es el cuidado del sueño?</h4>\n            </div>\n            <i class=\"ti ti-chevron-right text-white/20\" data-kid=\"41\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"relative\" data-kid=\"42\">\n          <div class=\"absolute -left-8 top-4 w-7 h-7 bg-[#0F172A] border border-mint-500 rounded-full flex items-center justify-center z-10 neon-glow-mint border-[#2DD4BF]\" data-kid=\"43\">\n            <i class=\"ti ti-check text-xs text-[#2DD4BF]\" data-kid=\"44\"></i>\n          </div>\n          <div class=\"glass rounded-2xl p-4 flex items-center border-[#2DD4BF]/30\" data-kid=\"45\">\n            <div class=\"w-10 h-10 bg-red-900/30 rounded-xl flex items-center justify-center mr-4\" data-kid=\"46\">\n              <i class=\"ti ti-activity text-red-400 text-lg\" data-kid=\"47\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"48\">\n              <span class=\"text-[10px] text-red-400 font-space font-bold uppercase\" data-kid=\"49\">02 BENEFICIOS</span>\n              <h4 class=\"text-sm font-semibold text-white/90\" data-kid=\"50\">Beneficios de cuidar tu sueño</h4>\n            </div>\n            <i class=\"ti ti-chevron-right text-white/20\" data-kid=\"51\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"relative\" data-kid=\"52\">\n          <div class=\"absolute -left-8 top-4 w-7 h-7 bg-[#A78BFA] rounded-full flex items-center justify-center z-10 neon-glow-lavender\" data-kid=\"53\">\n            <span class=\"text-[10px] font-bold text-[#0F172A]\" data-kid=\"54\">03</span>\n          </div>\n          <div class=\"glass rounded-2xl p-4 flex items-center border-white/20 ring-1 ring-white/10\" data-kid=\"55\">\n            <div class=\"w-10 h-10 bg-amber-900/30 rounded-xl flex items-center justify-center mr-4\" data-kid=\"56\">\n              <i class=\"ti ti-cpu text-amber-400 text-lg\" data-kid=\"57\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"58\">\n              <span class=\"text-[10px] text-amber-400 font-space font-bold uppercase\" data-kid=\"59\">03 CONTENIDO</span>\n              <h4 class=\"text-sm font-semibold text-white/90\" data-kid=\"60\">¿Qué incluye el cuidado?</h4>\n            </div>\n            <i class=\"ti ti-chevron-right text-white/40\" data-kid=\"61\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"relative opacity-60\" data-kid=\"62\">\n          <div class=\"absolute -left-8 top-4 w-7 h-7 bg-white/10 border border-white/20 rounded-full flex items-center justify-center z-10\" data-kid=\"63\">\n            <i class=\"ti ti-lock text-[10px]\" data-kid=\"64\"></i>\n          </div>\n          <div class=\"glass rounded-2xl p-4 flex items-center\" data-kid=\"65\">\n            <div class=\"w-10 h-10 bg-orange-900/20 rounded-xl flex items-center justify-center mr-4\" data-kid=\"66\">\n              <i class=\"ti ti-alert-triangle text-orange-400/50 text-lg\" data-kid=\"67\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"68\">\n              <span class=\"text-[10px] text-white/30 font-space font-bold uppercase\" data-kid=\"69\">04 RIESGOS</span>\n              <h4 class=\"text-sm font-semibold text-white/50\" data-kid=\"70\">¿Qué pasa si no cuido mi sueño?</h4>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"fixed bottom-6 left-6 right-6 z-50\" data-kid=\"71\">\n    <div class=\"glass rounded-2xl p-4 overflow-hidden relative border-l-4 border-purple-500\" data-kid=\"72\">\n      <div class=\"flex items-center\" data-kid=\"73\">\n        <div class=\"relative w-16 h-16 mr-4 shrink-0\" data-kid=\"74\">\n          <div class=\"absolute inset-0 bg-purple-500/20 rounded-xl blur-lg\" data-kid=\"75\"></div>\n          <img src=\"https://images.unsplash.com/photo-1583860323818-976007787a43?auto=format&w=200&q=80&fit=crop\" alt=\"Futuristic Pillow\" class=\"w-full h-full object-cover rounded-xl relative z-10\" decoding=\"async\" loading=\"lazy\" data-kid=\"76\">\n        </div>\n        <div class=\"flex-1\" data-kid=\"77\">\n          <h5 class=\"text-xs font-space font-bold text-indigo-300 uppercase tracking-widest\" data-kid=\"78\">System Message</h5>\n          <p class=\"text-sm font-semibold mt-0.5\" data-kid=\"79\">¡Sigue aprendiendo!</p>\n          <p class=\"text-[10px] text-white/50 leading-tight\" data-kid=\"80\">Cada pequeño cambio mejora tu descanso neuronal.</p>\n        </div>\n      </div>\n      \n      <div class=\"absolute -right-2 -bottom-2 w-16 h-16 border-r-2 border-b-2 border-white/5 rounded-br-2xl\" data-kid=\"81\"></div>\n    </div>\n  </div>\n</div>",
