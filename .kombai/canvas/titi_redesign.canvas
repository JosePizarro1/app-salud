      "html": "\n<div class=\"relative w-[375px] h-[812px] overflow-hidden flex flex-col items-center justify-between p-6 select-none\" style=\"background: linear-gradient(180deg, #1B263B 0%, #415A77 100%); font-family: 'Fredoka', sans-serif; color: #F0F0F0;\" data-kid=\"0\">\n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Nunito:wght@400;600;700&display=swap');\n        \n        .clay-button {\n            box-shadow: 0 8px 0 #C48B52, 0 15px 20px rgba(0,0,0,0.4);\n            transition: all 0.1s ease;\n        }\n        .clay-button:active {\n            transform: translateY(4px);\n            box-shadow: 0 4px 0 #C48B52, 0 8px 10px rgba(0,0,0,0.4);\n        }\n        \n        .clay-nav-item {\n            box-shadow: 0 6px 0 #5E738F, 0 10px 15px rgba(0,0,0,0.3);\n            transition: all 0.1s ease;\n        }\n        .clay-nav-item:active {\n            transform: translateY(3px);\n            box-shadow: 0 3px 0 #5E738F, 0 5px 8px rgba(0,0,0,0.3);\n        }\n\n        .clay-surface {\n            box-shadow: inset 0 4px 10px rgba(255,255,255,0.1), 0 15px 40px rgba(0,0,0,0.6);\n        }\n        \n        /* Ambient animation for Titi */\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n        .animate-float {\n            animation: float 4s ease-in-out infinite;\n        }\n\n        .star-glow {\n            filter: drop-shadow(0 0 15px rgba(224, 169, 109, 0.6));\n        }\n    </style>\n\n    \n    <div class=\"w-full flex justify-between items-center z-50\" data-kid=\"2\">\n        <button class=\"clay-button w-14 h-14 bg-[#E0A96D] rounded-full flex items-center justify-center border-2 border-white/20\" data-kid=\"3\">\n            <i class=\"ti ti-home text-white text-3xl\" data-kid=\"4\"></i>\n        </button>\n        <button class=\"clay-button w-14 h-14 bg-[#E0A96D] rounded-full flex items-center justify-center border-2 border-white/20\" data-kid=\"5\">\n            <i class=\"ti ti-settings text-white text-3xl\" data-kid=\"6\"></i>\n        </button>\n    </div>\n\n    \n    <div class=\"flex-1 w-full flex flex-col items-center justify-center relative -mt-20\" data-kid=\"7\">\n        <div class=\"relative animate-float\" data-kid=\"8\">\n            \n            <div class=\"relative w-80 h-80 flex items-center justify-center\" data-kid=\"9\">\n                \n                <div class=\"absolute inset-0 bg-white/5 rounded-full blur-[80px]\" data-kid=\"10\"></div>\n                \n                <div class=\"relative w-full h-full rounded-[100px] overflow-hidden border-[12px] border-white shadow-[0_35px_70px_rgba(0,0,0,0.8)] bg-white\" data-kid=\"11\">\n                    <img src=\"https://images.unsplash.com/photo-1739513275605-8f768065d402?auto=format&w=800&q=80&fit=crop\" alt=\"Titi\" class=\"w-full h-full object-cover scale-150 translate-y-6\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n                </div>\n            </div>\n            \n            <div class=\"absolute -bottom-10 left-1/2 -translate-x-1/2 bg-[#E0A96D] px-12 py-4 rounded-3xl shadow-[0_12px_0_#C48B52,0_25px_40px_rgba(0,0,0,0.6)] z-30 transform -rotate-1\" data-kid=\"13\">\n                <span class=\"text-white text-3xl font-black tracking-widest drop-shadow-md\" data-kid=\"14\">TITI</span>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"relative w-full z-20\" data-kid=\"15\">\n        \n        <div class=\"w-[120%] -left-[10%] relative bg-[#8B5E3C] h-60 rounded-t-[100px] shadow-[inset_0_8px_15px_rgba(255,255,255,0.1),0_20px_60px_rgba(0,0,0,0.8)] border-t-[12px] border-[#A67B5B] flex flex-col items-center pt-12\" data-kid=\"16\">\n            \n            \n            <div class=\"flex justify-around items-end w-full px-16 h-24 -mt-36\" data-kid=\"17\">\n                \n                <div class=\"w-20 h-20 bg-[#F0C987] rounded-full flex items-center justify-center shadow-[0_12px_0_#D4A76D,0_20px_30px_rgba(0,0,0,0.5)] relative group cursor-pointer active:translate-y-2 active:shadow-none transition-all\" data-kid=\"18\">\n                    <i class=\"ti ti-star-filled text-[#E0A96D] text-4xl star-glow\" data-kid=\"19\"></i>\n                    <div class=\"absolute inset-0 rounded-full bg-yellow-400/10 animate-pulse blur-xl\" data-kid=\"20\"></div>\n                </div>\n\n                \n                <div class=\"w-28 h-20 bg-[#415A77] rounded-[35px] flex flex-col items-center justify-center shadow-[0_12px_0_#2C3E50,0_20px_30px_rgba(0,0,0,0.5)] border-r-8 border-[#2C3E50] cursor-pointer active:translate-y-2 active:shadow-none transition-all\" data-kid=\"21\">\n                    <div class=\"flex gap-2 mb-2\" data-kid=\"22\">\n                        <div class=\"w-2 h-2 bg-white/30 rounded-full shadow-inner\" data-kid=\"23\"></div>\n                        <div class=\"w-2 h-2 bg-white/30 rounded-full shadow-inner\" data-kid=\"24\"></div>\n                    </div>\n                    <div class=\"w-16 h-10 bg-[#2C3E50] rounded-xl flex items-center justify-center\" data-kid=\"25\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/headphone.svg\" class=\"w-8 h-8 opacity-80\" alt=\"Music\" data-kid=\"26\">\n                    </div>\n                </div>\n\n                \n                <div class=\"w-24 h-16 bg-[#7B68EE] rounded-[40px] flex items-center justify-center shadow-[0_12px_0_#5A4FCF,0_20px_30px_rgba(0,0,0,0.5)] border-r-6 border-[#5A4FCF] cursor-pointer active:translate-y-2 active:shadow-none transition-all\" data-kid=\"27\">\n                    <div class=\"flex space-x-3\" data-kid=\"28\">\n                        <span class=\"text-white/40 text-3xl font-bold leading-none\" data-kid=\"29\">)</span>\n                        <span class=\"text-white/40 text-3xl font-bold leading-none\" data-kid=\"30\">(</span>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"mt-14 w-[85%] bg-[#2C3E50] p-5 rounded-[45px] flex justify-between shadow-[inset_0_4px_12px_rgba(0,0,0,0.6),0_15px_30px_rgba(0,0,0,0.4)] border-t border-white/5\" data-kid=\"31\">\n                \n                <button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"32\">\n                    <div class=\"clay-nav-item w-14 h-14 bg-[#E0A96D] rounded-full flex items-center justify-center border-t-2 border-white/20\" data-kid=\"33\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/open-book.svg\" class=\"w-8 h-8\" alt=\"Stories\" data-kid=\"34\">\n                    </div>\n                    <span class=\"text-[#F0F0F0] text-[10px] font-black uppercase tracking-widest opacity-80 group-hover:opacity-100\" data-kid=\"35\">Historias</span>\n                </button>\n                \n                \n                <button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"36\">\n                    <div class=\"clay-nav-item w-14 h-14 bg-[#778DA9] rounded-full flex items-center justify-center border-t-2 border-white/20\" data-kid=\"37\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/crescent-moon.svg\" class=\"w-8 h-8\" alt=\"Sleep\" data-kid=\"38\">\n                    </div>\n                    <span class=\"text-[#F0F0F0] text-[10px] font-black uppercase tracking-widest group-hover:opacity-100\" data-kid=\"39\">Sueño</span>\n                </button>\n\n                \n                <button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"40\">\n                    <div class=\"clay-nav-item w-14 h-14 bg-[#778DA9] rounded-full flex items-center justify-center border-t-2 border-white/20\" data-kid=\"41\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/alarm-clock.svg\" class=\"w-8 h-8\" alt=\"Routines\" data-kid=\"42\">\n                    </div>\n                    <span class=\"text-[#F0F0F0] text-[10px] font-black uppercase tracking-widest opacity-80 group-hover:opacity-100\" data-kid=\"43\">Rutinas</span>\n                </button>\n\n                \n                <button class=\"flex flex-col items-center gap-1.5 group cursor-pointer\" data-kid=\"44\">\n                    <div class=\"clay-nav-item w-14 h-14 bg-[#778DA9] rounded-full flex items-center justify-center border-t-2 border-white/20\" data-kid=\"45\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/headphone.svg\" class=\"w-8 h-8\" alt=\"Music\" data-kid=\"46\">\n                    </div>\n                    <span class=\"text-[#F0F0F0] text-[10px] font-black uppercase tracking-widest opacity-80 group-hover:opacity-100\" data-kid=\"47\">Música</span>\n                </button>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"absolute top-20 right-10 w-4 h-4 bg-white/20 rounded-full blur-sm\" data-kid=\"48\"></div>\n    <div class=\"absolute top-40 left-12 w-2 h-2 bg-white/10 rounded-full\" data-kid=\"49\"></div>\n    <div class=\"absolute bottom-60 right-20 w-3 h-3 bg-white/15 rounded-full blur-xs\" data-kid=\"50\"></div>\n\n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"51\">\n</div>\n",
