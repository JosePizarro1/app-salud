      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<div class=\"min-h-screen bg-gradient-to-b from-[#1B263B] to-[#415A77] font-['Nunito'] text-[#F0F0F0] overflow-x-hidden p-6 selection:bg-[#E0A96D]/30\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n      --clay-surface: #2C3E50;\n      --clay-accent: #E0A96D;\n      --clay-mint: #778DA9;\n      --clay-bg-dark: #1B263B;\n    }\n\n    .font-chunky { font-family: 'Fredoka One', cursive; }\n\n    .clay-card {\n      background-color: var(--clay-surface);\n      border-radius: 2.5rem;\n      box-shadow: \n        12px 12px 24px rgba(0, 0, 0, 0.5),\n        inset 4px 4px 12px #34495e,\n        inset -4px -4px 12px #223140;\n    }\n\n    .clay-card-flat {\n      background-color: var(--clay-surface);\n      border-radius: 1.5rem;\n      box-shadow: \n        8px 8px 16px rgba(0, 0, 0, 0.3),\n        inset 2px 2px 6px #34495e;\n    }\n\n    .clay-btn-circle {\n      background-color: var(--clay-accent);\n      width: 3.5rem;\n      height: 3.5rem;\n      border-radius: 9999px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: \n        8px 8px 16px rgba(0, 0, 0, 0.4),\n        inset 4px 4px 8px #f0c99f,\n        inset -4px -4px 8px #b17d4a;\n      color: var(--clay-bg-dark);\n      cursor: pointer;\n    }\n\n    .clay-toggle {\n      width: 4.5rem;\n      height: 2.25rem;\n      background-color: var(--clay-bg-dark);\n      border-radius: 9999px;\n      position: relative;\n      box-shadow: \n        inset 6px 6px 12px rgba(0, 0, 0, 0.6),\n        inset -2px -2px 4px #253147;\n      cursor: pointer;\n    }\n\n    .clay-toggle-thumb {\n      width: 1.75rem;\n      height: 1.75rem;\n      background-color: var(--clay-accent);\n      border-radius: 9999px;\n      position: absolute;\n      top: 0.25rem;\n      left: 0.25rem;\n      box-shadow: \n        4px 4px 8px rgba(0, 0, 0, 0.5),\n        inset 3px 3px 6px #f0c99f,\n        inset -3px -3px 6px #b17d4a;\n      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n    }\n\n    .clay-toggle.active .clay-toggle-thumb {\n      left: calc(100% - 2rem);\n    }\n\n    .clay-debossed-card {\n      background-color: var(--clay-surface);\n      border-radius: 2rem;\n      box-shadow: \n        inset 8px 8px 16px rgba(0, 0, 0, 0.5),\n        inset -4px -4px 8px #34495e;\n    }\n\n    /* Animation classes */\n    .animate-item {\n      opacity: 1; /* GSAP will handle initial state */\n    }\n    \n    .clay-glow-text {\n      color: #A0B4CF;\n      text-shadow: 2px 2px 0px #1B263B, -1px -1px 0px #F0F0F0;\n      position: relative;\n    }\n  </style>\n\n  <div class=\"max-w-md mx-auto h-full flex flex-col pt-4\" data-kid=\"2\">\n    \n    <header class=\"flex justify-between items-start mb-8\" data-kid=\"3\">\n      <div class=\"space-y-4\" data-kid=\"4\">\n        <button class=\"clay-btn-circle hover:scale-110 animate-item\" id=\"back-btn\" data-kid=\"5\">\n          <i class=\"ti ti-chevron-left text-2xl font-bold\" data-kid=\"6\"></i>\n        </button>\n        <div class=\"animate-item\" data-kid=\"7\">\n          <h1 class=\"text-4xl font-chunky leading-tight tracking-tight\" data-kid=\"8\">\n            Rutina de <br data-kid=\"9\">\n            <span class=\"clay-glow-text\" data-kid=\"10\">Sueño</span>\n          </h1>\n          <p class=\"text-[#8FA2B4] font-semibold mt-1\" data-kid=\"11\">Configurá tus alarmas y<br data-kid=\"12\">descansos saludables</p>\n        </div>\n      </div>\n      <div class=\"relative w-36 h-36 animate-item\" data-kid=\"13\">\n        \n        <div class=\"absolute inset-0 bg-[#E0A96D] opacity-10 blur-3xl rounded-full scale-150\" data-kid=\"14\"></div>\n        <img src=\"https://images.pexels.com/photos/11643390/pexels-photo-11643390.jpeg?auto=compress&cs=tinysrgb&w=300&q=80\" alt=\"Titi sleeping on cloud\" class=\"w-full h-full object-cover rounded-3xl drop-shadow-[0_20px_30px_rgba(0,0,0,0.7)] z-10 relative floating-anim\" decoding=\"async\" loading=\"lazy\" data-kid=\"15\">\n      </div>\n    </header>\n\n    \n    <main class=\"space-y-10\" data-kid=\"16\">\n      \n      \n      <section class=\"space-y-4 animate-item\" data-kid=\"17\">\n        <h2 class=\"text-xl font-chunky px-2\" data-kid=\"18\">Horario de Sueño</h2>\n        <div class=\"clay-card p-6 space-y-6\" data-kid=\"19\">\n          <div class=\"grid grid-cols-2 gap-3\" data-kid=\"20\">\n            \n            <div class=\"clay-card-flat p-3 flex flex-col items-center justify-center space-y-1\" data-kid=\"21\">\n              <span class=\"text-[var(--clay-mint)] text-[10px] font-bold uppercase tracking-widest flex items-center gap-1 whitespace-nowrap\" data-kid=\"22\">\n                <i class=\"ti ti-moon-stars\" data-kid=\"23\"></i> Acostarse\n              </span>\n              <span class=\"text-xl font-chunky whitespace-nowrap\" data-kid=\"24\">10:00 PM</span>\n            </div>\n            \n            <div class=\"clay-card-flat p-3 flex flex-col items-center justify-center space-y-1\" data-kid=\"25\">\n              <span class=\"text-[var(--clay-accent)] text-[10px] font-bold uppercase tracking-widest flex items-center gap-1 whitespace-nowrap\" data-kid=\"26\">\n                <i class=\"ti ti-sun\" data-kid=\"27\"></i> Despertar\n              </span>\n              <span class=\"text-xl font-chunky whitespace-nowrap\" data-kid=\"28\">6:00 AM</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex items-center justify-between pt-2\" data-kid=\"29\">\n            <div class=\"space-y-1\" data-kid=\"30\">\n              <h3 class=\"font-bold text-lg\" data-kid=\"31\">Alarma para despertar</h3>\n              <p class=\"text-[#A0B4CF] text-xs font-semibold\" data-kid=\"32\">Sona diaria a tu hora de despertar</p>\n            </div>\n            <div class=\"clay-toggle active\" id=\"alarm-toggle\" data-kid=\"33\">\n              <div class=\"clay-toggle-thumb\" data-kid=\"34\"></div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"space-y-4 animate-item\" data-kid=\"35\">\n        <div class=\"flex items-center justify-between px-2\" data-kid=\"36\">\n          <h2 class=\"text-xl font-chunky\" data-kid=\"37\">Tómate un descanso</h2>\n          <button class=\"w-10 h-10 bg-[var(--clay-accent)] rounded-full flex items-center justify-center shadow-lg text-[var(--clay-bg-dark)] hover:scale-110 active:scale-95\" data-kid=\"38\">\n            <i class=\"ti ti-plus text-xl font-bold\" data-kid=\"39\"></i>\n          </button>\n        </div>\n        \n        \n        <div class=\"clay-debossed-card p-12 flex flex-col items-center justify-center text-center space-y-4\" data-kid=\"40\">\n          <div class=\"w-16 h-16 bg-[#1b263b] rounded-full flex items-center justify-center shadow-inner border-2 border-[#34495e]\" data-kid=\"41\">\n            <i class=\"ti ti-bell-off text-3xl text-[#8FA2B4]\" data-kid=\"42\"></i>\n          </div>\n          <p class=\"text-[#8FA2B4] font-medium max-w-[200px]\" data-kid=\"43\">No tenés descansos programados</p>\n        </div>\n      </section>\n\n    </main>\n    \n    \n    <div class=\"mt-auto pt-10 opacity-20 pointer-events-none\" data-kid=\"44\">\n       <svg viewBox=\"0 0 400 100\" class=\"w-full\" data-kid=\"45\">\n         <path d=\"M0 50 Q 200 100 400 50 L 400 100 L 0 100 Z\" fill=\"var(--clay-bg-dark)\" data-kid=\"46\"></path>\n       </svg>\n    </div>\n  </div>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"47\"></script>\n  <script data-kid=\"48\">\n    document.addEventListener('DOMContentLoaded', () => {\n      // Entrance animation - using specific class\n      gsap.from('.animate-item', {\n        opacity: 0,\n        y: 30,\n        duration: 0.8,\n        stagger: 0.15,\n        ease: 'power3.out'\n      });\n\n      // Toggle functionality\n      const toggle = document.getElementById('alarm-toggle');\n      toggle.addEventListener('click', () => {\n        toggle.classList.toggle('active');\n        // Simple scale effect on click for plastic feel\n        gsap.fromTo(toggle, { scale: 0.95 }, { scale: 1, duration: 0.2, ease: 'back.out' });\n      });\n\n      // Hover effects for cards\n      const cards = document.querySelectorAll('.clay-card, .clay-card-flat');\n      cards.forEach(card => {\n        card.addEventListener('mouseenter', () => {\n          gsap.to(card, { y: -4, boxShadow: '16px 16px 32px rgba(0,0,0,0.5)', duration: 0.3 });\n        });\n        card.addEventListener('mouseleave', () => {\n          gsap.to(card, { y: 0, boxShadow: card.classList.contains('clay-card') ? '12px 12px 24px rgba(0, 0, 0, 0.4)' : '8px 8px 16px rgba(0, 0, 0, 0.3)', duration: 0.3 });\n        });\n      });\n\n      // Floating animation for Titi\n      gsap.to('.floating-anim', {\n        y: 10,\n        rotation: 2,\n        duration: 2,\n        repeat: -1,\n        yoyo: true,\n        ease: 'sine.inOut'\n      });\n    });\n  </script>\n</div>\n",
