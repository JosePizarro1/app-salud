      "html": "\n<div class=\"w-full min-h-screen bg-[#3B1F42] font-['Balsamiq_Sans'] text-[#FAFAFA] flex justify-center p-4 selection:bg-[#5BC0BE] selection:text-[#2D1432] overflow-x-clip\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Balsamiq+Sans:wght@400;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .paper-grain {\n            background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E\");\n            pointer-events: none;\n        }\n\n        .paper-shadow {\n            filter: drop-shadow(6px 6px 0px #1A0D1D);\n        }\n\n        .paper-card {\n            background-color: #2D1432;\n            position: relative;\n        }\n\n        .jagged-edge {\n            clip-path: polygon(\n                0 3%, 5% 0, 10% 4%, 15% 1%, 20% 5%, 25% 0, 30% 3%, 35% 0, 40% 5%, 45% 1%, 50% 4%, 55% 0, 60% 5%, 65% 1%, 70% 4%, 75% 0, 80% 5%, 85% 1%, 90% 4%, 95% 0, 100% 3%,\n                100% 97%, 95% 100%, 90% 96%, 85% 99%, 80% 95%, 75% 100%, 70% 97%, 65% 99%, 60% 95%, 55% 100%, 50% 96%, 45% 99%, 40% 95%, 35% 100%, 30% 97%, 25% 100%, 20% 95%, 15% 99%, 10% 96%, 5% 100%, 0 97%\n            );\n        }\n\n        .sticker-frame {\n            background: #FAFAFA;\n            padding: 8px 8px 16px 8px;\n            filter: drop-shadow(4px 4px 0px #1A0D1D);\n        }\n\n        .washi-tape {\n            background: #5BC0BE;\n            width: 50px;\n            height: 20px;\n            clip-path: polygon(0 0, 100% 0, 95% 50%, 100% 100%, 0 100%, 5% 50%);\n            filter: drop-shadow(1px 1px 0px #1A0D1D);\n        }\n\n        .toggle-track {\n            background: #1a0d1d;\n            border: 2px solid #2D1432;\n        }\n\n        .toggle-knob {\n            background: #5BC0BE;\n            filter: drop-shadow(3px 3px 0px #1A0D1D);\n        }\n\n        .dotted-edge {\n            clip-path: polygon(\n                0 2%, 10% 0, 20% 2%, 30% 0, 40% 2%, 50% 0, 60% 2%, 70% 0, 80% 2%, 90% 0, 100% 2%,\n                100% 98%, 90% 100%, 80% 98%, 70% 100%, 60% 98%, 50% 100%, 40% 98%, 30% 100%, 20% 98%, 10% 100%, 0 98%\n            );\n            background: #34193A;\n            border: 3px dashed #5BC0BE;\n        }\n\n        /* Decorative stars */\n        .star {\n            position: absolute;\n            background: #FDE74C;\n            clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);\n            opacity: 0.6;\n            z-index: 0;\n        }\n    </style>\n\n    \n    <div class=\"paper-grain fixed inset-0 z-50\" data-kid=\"2\"></div>\n\n    <div class=\"star w-4 h-4 top-[12%] left-[10%] rotate-12\" data-kid=\"3\"></div>\n    <div class=\"star w-3 h-3 top-[35%] left-[90%] -rotate-12\" data-kid=\"4\"></div>\n    <div class=\"star w-5 h-5 top-[65%] left-[8%] rotate-45\" data-kid=\"5\"></div>\n    <div class=\"star w-4 h-4 top-[88%] left-[80%] -rotate-6\" data-kid=\"6\"></div>\n    \n    \n    <div class=\"absolute top-[3%] right-[5%] w-24 h-24 bg-[#FDE74C] rounded-full paper-shadow -rotate-12 animate-moon z-0\" data-kid=\"7\">\n        <div class=\"absolute top-4 left-6 w-6 h-6 bg-[#D4BC3C] rounded-full\" data-kid=\"8\"></div>\n        <div class=\"absolute top-14 left-12 w-4 h-4 bg-[#D4BC3C] rounded-full\" data-kid=\"9\"></div>\n        <div class=\"absolute top-8 left-16 w-3 h-3 bg-[#D4BC3C] rounded-full\" data-kid=\"10\"></div>\n    </div>\n\n    <div class=\"w-full max-w-[375px] relative z-20 flex flex-col gap-8 pb-12 mt-6\" data-kid=\"11\">\n        \n        \n        <header class=\"flex justify-between items-start animate-item\" data-kid=\"12\">\n            <button class=\"w-12 h-12 bg-[#5BC0BE] text-[#2D1432] rounded-full flex items-center justify-center paper-shadow -rotate-6 hover:scale-105 active:scale-95 transition-transform cursor-pointer\" data-kid=\"13\">\n                <i class=\"ti ti-arrow-left text-2xl\" data-kid=\"14\"></i>\n            </button>\n\n            \n            <div class=\"relative mt-4 group\" data-kid=\"15\">\n                \n                <div class=\"washi-tape absolute -top-4 left-1/2 -translate-x-1/2 rotate-12 z-20\" data-kid=\"16\"></div>\n                \n                <div class=\"sticker-frame rotate-6 w-44 h-40 flex flex-col items-center\" data-kid=\"17\">\n                    <img src=\"https://images.unsplash.com/photo-1743883457828-4ba1fbfe637b?auto=format&w=400&q=80&fit=crop\" alt=\"Sleeping Ocelot\" class=\"w-full aspect-square object-cover rounded-xs\" decoding=\"async\" loading=\"lazy\" data-kid=\"18\">\n                    <div class=\"mt-2 text-[#2D1432] text-[10px] font-bold tracking-widest uppercase\" data-kid=\"19\">Titi durmiendo</div>\n                </div>\n            </div>\n        </header>\n\n        \n        <div class=\"animate-item\" data-kid=\"20\">\n            <h1 class=\"text-4xl font-bold leading-none tracking-tight\" data-kid=\"21\">\n                Rutina de <br data-kid=\"22\">\n                <span class=\"text-[#5BC0BE] text-6xl\" data-kid=\"23\">Sueño</span>\n            </h1>\n            <p class=\"text-[#9B88A0] mt-3 text-lg\" data-kid=\"24\">Configurá tus alarmas y descansos saludables</p>\n        </div>\n\n        \n        <section class=\"flex flex-col gap-4 animate-item\" data-kid=\"25\">\n            <h2 class=\"text-xl font-bold flex items-center gap-2\" data-kid=\"26\">\n                <span class=\"w-2 h-2 bg-[#5BC0BE] rotate-45\" data-kid=\"27\"></span>\n                Horario de Sueño\n            </h2>\n            \n            <div class=\"flex gap-4\" data-kid=\"28\">\n                \n                <div class=\"flex-1 paper-card jagged-edge p-5 rotate-1 paper-shadow group cursor-pointer hover:-rotate-1 transition-transform overflow-hidden\" data-kid=\"29\">\n                    <div class=\"absolute -top-1 -right-4 w-8 h-8 bg-[#5BC0BE] rotate-45 group-hover:bg-[#FDE74C] transition-colors\" data-kid=\"30\"></div>\n                    <div class=\"flex items-center gap-2 text-[#9B88A0] text-sm mb-2\" data-kid=\"31\">\n                        <i class=\"ti ti-moon text-[#FDE74C] text-lg\" data-kid=\"32\"></i>\n                        <span class=\"group-hover:text-[#FAFAFA]\" data-kid=\"33\">Acostarse</span>\n                    </div>\n                    <div class=\"text-2xl font-bold\" data-kid=\"34\">10:00 PM</div>\n                </div>\n\n                \n                <div class=\"flex-1 paper-card jagged-edge p-5 -rotate-2 paper-shadow group cursor-pointer hover:rotate-0 transition-transform overflow-hidden\" data-kid=\"35\">\n                    <div class=\"absolute -top-1 -right-4 w-8 h-8 bg-[#5BC0BE] rotate-45 group-hover:bg-[#FDE74C] transition-colors\" data-kid=\"36\"></div>\n                    <div class=\"flex items-center gap-2 text-[#9B88A0] text-sm mb-2\" data-kid=\"37\">\n                        <i class=\"ti ti-sun text-[#FDE74C] text-lg\" data-kid=\"38\"></i>\n                        <span class=\"group-hover:text-[#FAFAFA]\" data-kid=\"39\">Despertar</span>\n                    </div>\n                    <div class=\"text-2xl font-bold\" data-kid=\"40\">6:00 AM</div>\n                </div>\n            </div>\n\n            \n            <div class=\"paper-card jagged-edge p-6 mt-2 rotate-1 paper-shadow flex justify-between items-center group cursor-pointer active:rotate-0 transition-all\" data-kid=\"41\">\n                <div data-kid=\"42\">\n                    <h3 class=\"text-lg font-bold\" data-kid=\"43\">Alarma para despertar</h3>\n                    <p class=\"text-[#9B88A0] text-sm group-hover:text-[#FAFAFA] transition-colors\" data-kid=\"44\">Sona diaria a tu hora de despertar</p>\n                </div>\n                <div class=\"w-16 h-8 toggle-track rounded-full p-1 relative cursor-pointer overflow-hidden\" data-kid=\"45\">\n                    <div class=\"w-8 h-5 toggle-knob absolute right-1.5 top-1 rounded-sm rotate-2\" data-kid=\"46\"></div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"flex flex-col gap-4 animate-item\" data-kid=\"47\">\n            <div class=\"flex justify-between items-center\" data-kid=\"48\">\n                <h2 class=\"text-xl font-bold flex items-center gap-2\" data-kid=\"49\">\n                     <span class=\"w-2 h-2 bg-[#5BC0BE] rotate-45\" data-kid=\"50\"></span>\n                     Tómate un descanso\n                </h2>\n                <button class=\"w-10 h-10 bg-[#5BC0BE] text-[#2D1432] rounded-full flex items-center justify-center paper-shadow rotate-12 hover:scale-110 transition-transform cursor-pointer\" data-kid=\"51\">\n                    <i class=\"ti ti-plus text-xl\" data-kid=\"52\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"w-full dotted-edge p-10 flex flex-col items-center justify-center -rotate-1 gap-4 paper-shadow\" data-kid=\"53\">\n                <div class=\"w-16 h-16 bg-[#2D1432] rounded-full flex items-center justify-center text-[#9B88A0] border-2 border-dashed border-[#5BC0BE]\" data-kid=\"54\">\n                    <i class=\"ti ti-bell-off text-3xl\" data-kid=\"55\"></i>\n                </div>\n                <p class=\"text-[#9B88A0] text-center font-bold uppercase tracking-wider text-xs\" data-kid=\"56\">No tenés descansos programados</p>\n            </div>\n        </section>\n\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"57\"></script>\n    <script data-kid=\"58\">\n        document.addEventListener('DOMContentLoaded', () => {\n            gsap.from('.animate-item', {\n                y: 60,\n                opacity: 0,\n                rotation: () => gsap.utils.random(-5, 5),\n                duration: 1,\n                stagger: 0.15,\n                ease: 'power3.out'\n            });\n\n            gsap.from('.star', {\n                scale: 0,\n                opacity: 0,\n                duration: 1,\n                stagger: 0.2,\n                ease: 'back.out(2)',\n                delay: 0.5\n            });\n\n            gsap.from('.animate-moon', {\n                x: 100,\n                y: -100,\n                opacity: 0,\n                rotation: -45,\n                duration: 1.5,\n                ease: 'power2.out',\n                delay: 0.8\n            });\n            \n            // Subtle breathing/floating for stars\n            gsap.to('.star', {\n                y: '+=12',\n                rotation: '+=20',\n                duration: 3,\n                repeat: -1,\n                yoyo: true,\n                ease: 'sine.inOut',\n                stagger: {\n                    amount: 1.5,\n                    from: 'random'\n                }\n            });\n        });\n    </script>\n</div>\n",
