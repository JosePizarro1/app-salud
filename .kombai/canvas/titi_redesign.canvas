      "html": "\n<div class=\"min-h-screen bg-[#1A1A2E] text-white p-6 font-['Work_Sans'] selection:bg-[#4ECDC4] selection:text-[#1A1A2E]\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Lilita+One&family=Work+Sans:wght@400;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-lilita { font-family: 'Lilita One', cursive; }\n    \n    .chunky-card {\n      background-color: #16213E;\n      border: 4px solid #000000;\n      box-shadow: 8px 8px 0px 0px #000000;\n      border-radius: 1.5rem;\n      transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s ease;\n    }\n\n    .chunky-card:active {\n      transform: translate(4px, 4px);\n      box-shadow: 4px 4px 0px 0px #000000;\n    }\n\n    .sticker-container {\n      filter: drop-shadow(6px 6px 0px #000);\n      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    }\n\n    .sticker-container:hover {\n      transform: rotate(-3deg) scale(1.05);\n    }\n\n    /* Custom scrollbar for better look */\n    ::-webkit-scrollbar {\n      width: 8px;\n    }\n    ::-webkit-scrollbar-track {\n      background: #1A1A2E;\n    }\n    ::-webkit-scrollbar-thumb {\n      background: #16213E;\n      border: 2px solid #000;\n      border-radius: 4px;\n    }\n  </style>\n\n  \n  <header class=\"flex items-start justify-between mb-12 animate-header\" data-kid=\"2\">\n    <div class=\"flex flex-col gap-6\" data-kid=\"3\">\n      <button class=\"w-12 h-12 bg-white text-black border-4 border-black shadow-[4px_4px_0px_0px_#000] rounded-xl flex items-center justify-center text-2xl hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-pointer\" data-kid=\"4\">\n        <i class=\"ti ti-arrow-left\" data-kid=\"5\"></i>\n      </button>\n      <div data-kid=\"6\">\n        <h1 class=\"text-5xl font-lilita leading-none mb-1\" data-kid=\"7\">\n          Rutina de\n        </h1>\n        <h1 class=\"text-5xl font-lilita leading-none text-[#4ECDC4]\" data-kid=\"8\">\n          Sueño\n        </h1>\n        <p class=\"text-white text-lg font-medium mt-4 max-w-[220px] leading-snug\" data-kid=\"9\">\n          Configurá tus alarmas y descansos saludables\n        </p>\n      </div>\n    </div>\n    \n    \n    <div class=\"relative sticker-container animate-titi\" data-kid=\"10\">\n      <div class=\"w-36 h-36 rounded-3xl border-4 border-black bg-[#16213E] overflow-hidden p-1\" data-kid=\"11\">\n        <img src=\"https://images.pexels.com/photos/28517671/pexels-photo-28517671.jpeg?auto=compress&cs=tinysrgb&w=400&q=80\" alt=\"Titi sleeping\" class=\"w-full h-full object-cover rounded-2xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n      </div>\n      <div class=\"absolute -bottom-3 -right-3 w-12 h-12 bg-[#FF6B6B] border-4 border-black rounded-full flex items-center justify-center text-black\" data-kid=\"13\">\n        <i class=\"ti ti-moon-filled text-2xl\" data-kid=\"14\"></i>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"mb-10 animate-schedule\" data-kid=\"15\">\n    <h2 class=\"text-2xl font-lilita mb-6 flex items-center gap-3\" data-kid=\"16\">\n      <i class=\"ti ti-clock-filled text-[#4ECDC4]\" data-kid=\"17\"></i>\n      Horario de Sueño\n    </h2>\n    <div class=\"grid grid-cols-2 gap-5\" data-kid=\"18\">\n      \n      <div class=\"chunky-card p-6 flex flex-col items-center gap-3 group\" data-kid=\"19\">\n        <div class=\"w-16 h-16 bg-[#0B132B] border-2 border-black rounded-2xl flex items-center justify-center text-[#4ECDC4] text-5xl group-hover:scale-110 transition-transform\" data-kid=\"20\">\n          <i class=\"ti ti-moon-stars\" data-kid=\"21\"></i>\n        </div>\n        <div class=\"text-center\" data-kid=\"22\">\n          <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-white block mb-1\" data-kid=\"23\">Acostarse</span>\n          <span class=\"text-2xl font-lilita whitespace-nowrap\" data-kid=\"24\">10:00 PM</span>\n        </div>\n      </div>\n      \n      <div class=\"chunky-card p-6 flex flex-col items-center gap-3 group\" data-kid=\"25\">\n        <div class=\"w-16 h-16 bg-[#0B132B] border-2 border-black rounded-2xl flex items-center justify-center text-[#FF6B6B] text-5xl group-hover:scale-110 transition-transform\" data-kid=\"26\">\n          <i class=\"ti ti-sun-filled\" data-kid=\"27\"></i>\n        </div>\n        <div class=\"text-center\" data-kid=\"28\">\n          <span class=\"text-[10px] uppercase font-bold tracking-[0.2em] text-white block mb-1\" data-kid=\"29\">Despertar</span>\n          <span class=\"text-2xl font-lilita whitespace-nowrap\" data-kid=\"30\">6:00 AM</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"mb-10 animate-alarm\" data-kid=\"31\">\n    <div class=\"chunky-card p-6 flex items-center justify-between\" data-kid=\"32\">\n      <div class=\"flex items-center gap-4\" data-kid=\"33\">\n        <div class=\"w-12 h-12 bg-[#0B132B] border-2 border-black rounded-xl flex items-center justify-center text-[#FF6B6B] text-2xl\" data-kid=\"34\">\n          <i class=\"ti ti-alarm-filled\" data-kid=\"35\"></i>\n        </div>\n        <div data-kid=\"36\">\n          <h3 class=\"text-xl font-lilita leading-tight\" data-kid=\"37\">Alarma</h3>\n          <p class=\"text-sm text-white\" data-kid=\"38\">Sona a la hora de despertar</p>\n        </div>\n      </div>\n      \n      \n      <div class=\"w-20 h-10 bg-[#0B132B] border-4 border-black rounded-full relative cursor-pointer overflow-hidden toggle-container\" data-kid=\"39\">\n        <div class=\"absolute inset-0 bg-[#000000] toggle-bg\" data-kid=\"40\"></div>\n        <div class=\"w-8 h-8 bg-[#FF6B6B] border-2 border-black rounded-full absolute top-0.5 left-0.5 transform translate-x-9 shadow-[2px_2px_0px_0px_#000] toggle-knob\" data-kid=\"41\"></div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"animate-breaks\" data-kid=\"42\">\n    <div class=\"flex items-center justify-between mb-6\" data-kid=\"43\">\n      <h2 class=\"text-2xl font-lilita flex items-center gap-3\" data-kid=\"44\">\n        <i class=\"ti ti-cup-filled text-[#4ECDC4]\" data-kid=\"45\"></i>\n        Tómate un descanso\n      </h2>\n      <button class=\"w-12 h-12 bg-[#4ECDC4] text-black border-4 border-black shadow-[4px_4px_0px_0px_#000] rounded-2xl flex items-center justify-center text-3xl hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all cursor-pointer\" data-kid=\"46\">\n        <i class=\"ti ti-plus\" data-kid=\"47\"></i>\n      </button>\n    </div>\n    \n    \n    <div class=\"bg-[#16213E] border-4 border-black rounded-3xl p-12 flex flex-col items-center justify-center text-center gap-6 shadow-[8px_8px_0px_0px_#000]\" data-kid=\"48\">\n      <div class=\"w-20 h-20 bg-[#0B132B] border-4 border-black rounded-full flex items-center justify-center text-5xl text-white\" data-kid=\"49\">\n        <i class=\"ti ti-bell-off\" data-kid=\"50\"></i>\n      </div>\n      <div class=\"max-w-[180px]\" data-kid=\"51\">\n        <p class=\"text-2xl font-lilita text-white mb-1\" data-kid=\"52\">Silencio total</p>\n        <p class=\"text-sm text-white\" data-kid=\"53\">No tenés descansos programados aún</p>\n      </div>\n    </div>\n  </section>\n\n  <div class=\"h-10\" data-kid=\"54\"></div>\n\n  \n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"55\"></script>\n  <script data-kid=\"56\">\n    document.addEventListener('DOMContentLoaded', () => {\n      // Entrance Animations\n      const tl = gsap.timeline({ defaults: { ease: \"back.out(1.7)\", duration: 0.8 } });\n      \n      tl.from(\".animate-header\", { y: -50, opacity: 0 })\n        .from(\".animate-titi\", { scale: 0, rotation: -15 }, \"-=0.6\")\n        .from(\".animate-schedule\", { y: 30, opacity: 0 }, \"-=0.6\")\n        .from(\".animate-alarm\", { y: 30, opacity: 0 }, \"-=0.6\")\n        .from(\".animate-breaks\", { y: 30, opacity: 0 }, \"-=0.6\");\n\n      // Toggle Interaction\n      const toggle = document.querySelector('.toggle-container');\n      const knob = toggle.querySelector('.toggle-knob');\n      const bg = toggle.querySelector('.toggle-bg');\n      let isActive = true;\n\n      // Ensure initial position is correct (x: 36 matches translate-x-9)\n      gsap.set(knob, { x: 36 });\n\n      toggle.addEventListener('click', () => {\n        isActive = !isActive;\n        gsap.to(knob, { \n          x: isActive ? 36 : 0, \n          backgroundColor: isActive ? \"#FF6B6B\" : \"#FFFFFF\",\n          duration: 0.3,\n          ease: \"back.out(1.2)\"\n        });\n        gsap.to(bg, {\n          backgroundColor: isActive ? \"#000000\" : \"#1A1A2E\",\n          duration: 0.3\n        });\n      });\n    });\n  </script>\n</div>\n",
