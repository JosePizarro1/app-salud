      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lilita+One&family=Work+Sans:wght@400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-indigo: #1A1A2E;\n    --accent-coral: #FF6B6B;\n    --accent-cyan: #4ECDC4;\n    --surface-slate: #16213E;\n    --white: #FFFFFF;\n    --black: #000000;\n    --yellow: #FFE66D;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--bg-indigo);\n    font-family: 'Work Sans', sans-serif;\n  }\n\n  .chunky-border {\n    border: 4px solid var(--black);\n  }\n\n  .hard-shadow {\n    box-shadow: 8px 8px 0px var(--black);\n  }\n\n  .hard-shadow-sm {\n    box-shadow: 6px 6px 0px var(--black);\n  }\n\n  .hard-shadow-xs {\n    box-shadow: 4px 4px 0px var(--black);\n  }\n\n  .font-lilita {\n    font-family: 'Lilita One', cursive;\n  }\n\n  .sticker-effect {\n    filter: drop-shadow(4px 4px 0px rgba(0,0,0,1));\n  }\n\n  /* Sticker wrapper: white border + black border */\n  .sticker-wrapper {\n    position: relative;\n    padding: 6px;\n    background: var(--white);\n    border: 4px solid var(--black);\n    box-shadow: 8px 8px 0px var(--black);\n  }\n\n  .btn-pop {\n    /* Transitions removed to avoid GSAP conflict */\n  }\n\n  .interactive-item {\n     /* Transitions removed to avoid GSAP conflict */\n  }\n</style>\n\n<div class=\"w-[375px] h-[812px] bg-[var(--bg-indigo)] relative flex flex-col overflow-x-clip font-work text-white\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute top-0 left-0 w-full h-full pointer-events-none\" data-kid=\"2\">\n      <div class=\"absolute top-[8%] right-[-12%] w-48 h-48 bg-[#2A2A4A] chunky-border rotate-12\" data-kid=\"3\"></div>\n      <div class=\"absolute bottom-[25%] left-[-18%] w-72 h-72 bg-[#252545] chunky-border -rotate-6\" data-kid=\"4\"></div>\n      \n      <div class=\"absolute top-32 left-10 w-3 h-3 bg-[var(--yellow)] rounded-full animate-pulse\" data-kid=\"5\"></div>\n      <div class=\"absolute top-52 right-20 w-4 h-4 bg-[var(--yellow)] rounded-full animate-pulse delay-700\" data-kid=\"6\"></div>\n      <div class=\"absolute bottom-72 right-12 w-3 h-3 bg-[var(--yellow)] rounded-full animate-pulse delay-1000\" data-kid=\"7\"></div>\n  </div>\n\n  \n  <header class=\"p-6 flex justify-between items-center z-20\" data-kid=\"8\">\n    <button class=\"w-14 h-14 bg-[var(--accent-coral)] chunky-border hard-shadow-sm flex items-center justify-center rounded-2xl btn-pop\" data-kid=\"9\">\n      <i class=\"ti ti-home text-3xl\" data-kid=\"10\"></i>\n    </button>\n    <div class=\"bg-[var(--white)] chunky-border hard-shadow-sm px-6 py-2 rounded-2xl\" data-kid=\"11\">\n      <span class=\"font-lilita text-2xl text-[var(--black)] tracking-tight\" data-kid=\"12\">HABITACIÓN</span>\n    </div>\n    <button class=\"w-14 h-14 bg-[var(--accent-cyan)] chunky-border hard-shadow-sm flex items-center justify-center rounded-2xl btn-pop\" data-kid=\"13\">\n      <i class=\"ti ti-alert-triangle text-3xl\" data-kid=\"14\"></i>\n    </button>\n  </header>\n\n  \n  <main class=\"flex-1 flex flex-col relative z-10 px-6 pt-2\" data-kid=\"15\">\n    \n    \n    <div class=\"flex-none flex flex-col items-center justify-center relative pt-8 pb-12\" data-kid=\"16\">\n      \n      <div id=\"titi-container\" class=\"relative group cursor-pointer\" data-kid=\"17\">\n        <div class=\"sticker-wrapper rounded-[48px] overflow-hidden w-56 h-56 bg-[var(--white)]\" data-kid=\"18\">\n          \n          <img src=\"https://images.pexels.com/photos/13676788/pexels-photo-13676788.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Titi the Ocelot\" class=\"w-full h-full object-cover brightness-105 contrast-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"19\">\n        </div>\n        \n        <div class=\"absolute -top-10 -right-4 bg-[var(--white)] chunky-border hard-shadow-sm px-4 py-2 rounded-tr-3xl rounded-tl-3xl rounded-br-3xl rotate-12\" data-kid=\"20\">\n           <p class=\"font-lilita text-[var(--black)] text-lg\" data-kid=\"21\">¡HOLA!</p>\n        </div>\n        \n        <div class=\"absolute -bottom-6 left-1/2 -translate-x-1/2 bg-[var(--accent-coral)] chunky-border hard-shadow-sm px-8 py-2 rounded-2xl\" data-kid=\"22\">\n          <h1 class=\"font-lilita text-3xl text-white tracking-widest\" data-kid=\"23\">TITI</h1>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"w-full mt-auto relative pb-48\" data-kid=\"24\">\n        \n        <div class=\"absolute bottom-[-60px] left-[-40px] w-[calc(100%+80px)] h-56 bg-[#0F0F1D] chunky-border -z-10 rounded-t-[80px]\" data-kid=\"25\"></div>\n\n        \n        <div class=\"w-full h-16 bg-[#A5A58D] chunky-border hard-shadow rounded-2xl relative flex items-center justify-center\" data-kid=\"26\">\n            \n            \n            <div class=\"absolute -top-24 left-6 group interactive-item cursor-pointer flex flex-col items-center\" data-kid=\"27\">\n                <div class=\"w-20 h-20 bg-[var(--yellow)] chunky-border hard-shadow-xs rounded-full flex items-center justify-center relative\" data-kid=\"28\">\n                    <div class=\"w-4 h-6 bg-[var(--black)] absolute bottom-[-10px] rounded-sm\" data-kid=\"29\"></div>\n                    <i class=\"ti ti-bulb text-4xl text-[var(--black)]\" data-kid=\"30\"></i>\n                </div>\n                <div class=\"mt-2 bg-[var(--white)] chunky-border hard-shadow-xs px-3 py-0.5 rounded-xl text-[var(--black)] font-lilita text-sm z-10\" data-kid=\"31\">LUZ</div>\n            </div>\n\n            \n            <div class=\"absolute -top-28 right-6 group interactive-item cursor-pointer flex flex-col items-center\" data-kid=\"32\">\n                <div class=\"w-24 h-28 bg-[var(--accent-cyan)] chunky-border hard-shadow-xs rounded-3xl flex flex-col items-center justify-center p-2 rotate-6\" data-kid=\"33\">\n                    <div class=\"w-full h-full bg-[var(--black)] rounded-xl flex items-center justify-center overflow-hidden\" data-kid=\"34\">\n                         \n                         <img src=\"https://images.pexels.com/photos/6289025/pexels-photo-6289025.jpeg?auto=compress&cs=tinysrgb&w=300&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Music\" decoding=\"async\" loading=\"lazy\" data-kid=\"35\">\n                         <i class=\"ti ti-music text-white text-3xl absolute drop-shadow-[2px_2px_0px_rgba(0,0,0,1)]\" data-kid=\"36\"></i>\n                    </div>\n                </div>\n                <div class=\"mt-1 bg-[var(--white)] chunky-border hard-shadow-xs px-3 py-0.5 rounded-xl text-[var(--black)] font-lilita text-sm -rotate-3 z-10\" data-kid=\"37\">MÚSICA</div>\n            </div>\n        </div>\n    </div>\n\n  </main>\n\n  \n  <nav class=\"absolute bottom-10 left-1/2 -translate-x-1/2 w-[92%] z-30\" data-kid=\"38\">\n    <div class=\"bg-[var(--surface-slate)] chunky-border hard-shadow rounded-[40px] p-3 flex items-center justify-between\" data-kid=\"39\">\n      \n      \n      <button class=\"w-14 h-14 bg-[var(--white)] chunky-border hard-shadow-xs rounded-2xl flex items-center justify-center text-[var(--black)] btn-pop\" data-kid=\"40\">\n        <i class=\"ti ti-book text-3xl\" data-kid=\"41\"></i>\n      </button>\n\n      <button class=\"w-20 h-20 bg-[var(--accent-coral)] chunky-border hard-shadow-sm rounded-2xl flex items-center justify-center text-white -translate-y-8 scale-110 btn-pop\" data-kid=\"42\">\n        <i class=\"ti ti-moon-stars text-5xl\" data-kid=\"43\"></i>\n      </button>\n\n      <button class=\"w-14 h-14 bg-[var(--white)] chunky-border hard-shadow-xs rounded-2xl flex items-center justify-center text-[var(--black)] btn-pop\" data-kid=\"44\">\n        <i class=\"ti ti-clock-filled text-3xl\" data-kid=\"45\"></i>\n      </button>\n\n      <button class=\"w-14 h-14 bg-[var(--white)] chunky-border hard-shadow-xs rounded-2xl flex items-center justify-center text-[var(--black)] btn-pop\" data-kid=\"46\">\n        <i class=\"ti ti-headphones-filled text-3xl\" data-kid=\"47\"></i>\n      </button>\n\n    </div>\n  </nav>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"48\"></script>\n<script data-kid=\"49\">\n  window.addEventListener('DOMContentLoaded', () => {\n    // Entrance Animations\n    const tl = gsap.timeline({ defaults: { ease: \"back.out(1.7)\", duration: 0.6 } });\n\n    tl.from(\"header\", { y: -50, opacity: 0 })\n      .from(\"#titi-container\", { scale: 0, rotation: -15 }, \"-=0.3\")\n      .from(\".interactive-item\", { scale: 0, stagger: 0.1 }, \"-=0.4\")\n      .from(\"nav\", { y: 100, opacity: 0 }, \"-=0.3\");\n\n    // Interactive States via GSAP\n    const interactiveItems = document.querySelectorAll('.interactive-item, .btn-pop, #titi-container');\n    interactiveItems.forEach(item => {\n      item.addEventListener('mouseenter', () => {\n        gsap.to(item, { scale: 1.05, rotation: item.classList.contains('rotate-6') ? 10 : (item.classList.contains('-rotate-3') ? -1 : 2), duration: 0.3, ease: \"power2.out\" });\n      });\n      item.addEventListener('mouseleave', () => {\n        gsap.to(item, { scale: 1, rotation: item.classList.contains('rotate-6') ? 6 : (item.classList.contains('-rotate-3') ? -3 : 0), duration: 0.3, ease: \"power2.out\" });\n      });\n      item.addEventListener('mousedown', () => {\n        gsap.to(item, { y: 4, x: 4, boxShadow: \"0px 0px 0px #000\", duration: 0.1 });\n      });\n      item.addEventListener('mouseup', () => {\n        const shadowVal = item.classList.contains('hard-shadow-sm') ? \"6px 6px 0px #000\" : (item.classList.contains('hard-shadow-xs') ? \"4px 4px 0px #000\" : \"8px 8px 0px #000\");\n        gsap.to(item, { y: 0, x: 0, boxShadow: shadowVal, duration: 0.1 });\n      });\n    });\n  });\n</script>\n",
