      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Balsamiq+Sans:wght@700&family=Quicksand:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-deep-plum: #3B1F42;\n    --primary-yellow: #FDE74C;\n    --secondary-teal: #5BC0BE;\n    --surface-eggplant: #2D1432;\n    --text-cream: #FAFAFA;\n    --text-lilac: #9B88A0;\n    --paper-shadow: 0 4px 0 rgba(0, 0, 0, 0.4);\n    --sticker-border: 4px solid white;\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Quicksand', sans-serif;\n    color: var(--text-cream);\n    background: var(--bg-deep-plum);\n    user-select: none;\n    overflow: hidden;\n  }\n\n  .paper-font {\n    font-family: 'Balsamiq Sans', cursive;\n  }\n\n  .paper-depth {\n    filter: drop-shadow(4px 4px 0px rgba(0, 0, 0, 0.4));\n  }\n\n  .paper-depth-sm {\n    filter: drop-shadow(2px 2px 0px rgba(0, 0, 0, 0.3));\n  }\n\n  .sticker {\n    border: var(--sticker-border);\n    box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.3);\n  }\n\n  .scalloped-edge {\n    background: var(--surface-eggplant);\n    position: relative;\n  }\n\n  .scalloped-edge::before {\n    content: \"\";\n    position: absolute;\n    top: -24px;\n    left: 0;\n    width: 100%;\n    height: 30px;\n    background: radial-gradient(circle at 15px 24px, var(--surface-eggplant) 14px, transparent 15px);\n    background-size: 30px 30px;\n    filter: drop-shadow(0px -4px 0px rgba(0,0,0,0.2));\n  }\n\n  .paper-texture {\n    background-image: url(\"https://www.transparenttextures.com/patterns/felt.png\");\n    mix-blend-mode: soft-light;\n  }\n\n  /* Custom shapes for papercraft scenery */\n  .hill-1 { clip-path: polygon(0% 100%, 100% 100%, 100% 40%, 80% 60%, 60% 30%, 40% 70%, 20% 40%, 0% 80%); }\n  .hill-2 { clip-path: polygon(0% 100%, 100% 100%, 100% 50%, 85% 30%, 70% 60%, 50% 20%, 30% 70%, 15% 40%, 0% 60%); }\n</style>\n\n<div class=\"relative w-[375px] h-[812px] bg-[var(--bg-deep-plum)] overflow-hidden flex flex-col mx-auto\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 z-0\" data-kid=\"2\">\n    \n    <div class=\"absolute top-20 left-10 w-4 h-4 bg-[var(--primary-yellow)] rotate-45 paper-depth-sm star\" data-kid=\"3\"></div>\n    <div class=\"absolute top-44 right-24 w-3 h-3 bg-white rotate-12 paper-depth-sm star\" data-kid=\"4\"></div>\n    <div class=\"absolute top-72 left-1/4 w-2 h-2 bg-[var(--text-lilac)] rotate-45 paper-depth-sm star\" data-kid=\"5\"></div>\n    <div class=\"absolute top-52 right-1/3 w-1.5 h-1.5 bg-white rounded-full star opacity-50\" data-kid=\"6\"></div>\n    <div class=\"absolute top-16 left-1/2 w-1 h-1 bg-[var(--primary-yellow)] rounded-full star opacity-40\" data-kid=\"7\"></div>\n    \n    \n    <div class=\"absolute top-24 right-6 w-16 h-16 bg-[var(--primary-yellow)] rounded-full paper-depth moon z-0\" style=\"clip-path: path('M16 0A16 16 0 1016 32 12 12 0 1116 0z'); transform: scale(2) rotate(-15deg);\" data-kid=\"8\">\n    </div>\n  </div>\n\n  \n  <div class=\"absolute bottom-[120px] left-0 w-full h-1/2 z-1\" data-kid=\"9\">\n    <div class=\"absolute bottom-0 left-0 w-full h-[360px] bg-[#221026] hill-1 paper-depth opacity-90\" data-kid=\"10\"></div>\n    <div class=\"absolute bottom-0 left-0 w-full h-[280px] bg-[#311C36] hill-2 paper-depth\" data-kid=\"11\"></div>\n  </div>\n\n  \n  <header class=\"relative z-50 flex justify-between items-center p-6 pt-10\" data-kid=\"12\">\n    <button class=\"w-14 h-14 bg-[var(--secondary-teal)] sticker rounded-full flex items-center justify-center text-white active:scale-95 transition-transform hover:rotate-3\" data-kid=\"13\">\n      <i class=\"ti ti-home text-2xl\" data-kid=\"14\"></i>\n    </button>\n    <div class=\"bg-white/10 px-4 py-2 rounded-full sticker backdrop-blur-none border-white/50\" data-kid=\"15\">\n       <span class=\"paper-font text-lg text-white\" data-kid=\"16\">Habitación</span>\n    </div>\n    <button class=\"w-14 h-14 bg-[var(--primary-yellow)] sticker rounded-full flex items-center justify-center text-[var(--bg-deep-plum)] active:scale-95 transition-transform hover:-rotate-3\" data-kid=\"17\">\n      <i class=\"ti ti-alert-circle text-2xl\" data-kid=\"18\"></i>\n    </button>\n  </header>\n\n  \n  <main class=\"relative flex-grow flex flex-col items-center justify-center z-10 -mt-32\" data-kid=\"19\">\n    \n    <div class=\"relative w-64 h-64 character-container\" data-kid=\"20\">\n      <div class=\"absolute inset-0 bg-[var(--primary-yellow)]/10 rounded-full blur-3xl opacity-30\" data-kid=\"21\"></div>\n      <div class=\"relative w-full h-full sticker bg-[#F8F9FA] rounded-[48px] p-5 overflow-hidden paper-depth titi-paper\" data-kid=\"22\">\n        <div class=\"absolute inset-0 paper-texture opacity-30\" data-kid=\"23\"></div>\n        <img src=\"https://images.unsplash.com/photo-1754420854753-d0ab2d44edd7?auto=format&w=500&q=80&fit=crop\" alt=\"Titi Ocelot\" class=\"w-full h-full object-contain scale-110 filter saturate-150 contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"24\">\n        \n        <div class=\"absolute bottom-4 left-1/2 -translate-x-1/2 bg-[var(--secondary-teal)] px-6 py-2 sticker rounded-2xl -rotate-2 paper-depth-sm\" data-kid=\"25\">\n          <span class=\"paper-font text-xl text-white uppercase tracking-widest\" data-kid=\"26\">TITI</span>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <section class=\"relative z-20 w-full h-56 flex flex-col items-center justify-end px-2 pb-32\" data-kid=\"27\">\n    \n    <div class=\"relative w-full h-24 bg-[#4D2A54] border-t-8 border-[#633A6B] paper-depth rounded-t-[40px] table-paper flex items-center justify-center\" data-kid=\"28\">\n      <div class=\"absolute top-2 w-32 h-1 bg-black/10 rounded-full\" data-kid=\"29\"></div>\n      \n      \n      <div class=\"absolute -top-28 left-4 w-24 h-32 paper-depth hover-item z-20\" style=\"transform: rotate(-6deg);\" data-kid=\"30\">\n        <div class=\"relative w-full h-full bg-white sticker rounded-2xl p-2\" data-kid=\"31\">\n          <img src=\"https://images.pexels.com/photos/15273825/pexels-photo-15273825.jpeg?auto=compress&cs=tinysrgb&w=300&q=80\" alt=\"Paper Lamp\" class=\"w-full h-full object-cover rounded-xl filter saturate-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n          <div class=\"absolute inset-2 bg-[var(--primary-yellow)]/20 mix-blend-color rounded-xl\" data-kid=\"33\"></div>\n          <div class=\"absolute inset-0 paper-texture opacity-40\" data-kid=\"34\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute -top-24 right-4 w-20 h-32 paper-depth hover-item z-10\" style=\"transform: rotate(8deg);\" data-kid=\"35\">\n        <div class=\"relative w-full h-full bg-white sticker rounded-[32px] p-2 overflow-hidden\" data-kid=\"36\">\n           <img src=\"https://images.pexels.com/photos/23496775/pexels-photo-23496775.jpeg?auto=compress&cs=tinysrgb&w=300&q=80\" alt=\"Music Device\" class=\"w-full h-full object-cover rounded-2xl filter saturate-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"37\">\n          <div class=\"absolute inset-0 paper-texture opacity-40\" data-kid=\"38\"></div>\n          <div class=\"absolute bottom-2 left-1/2 -translate-x-1/2 w-4 h-4 bg-[#CBD5E1] border-2 border-white rounded-full\" data-kid=\"39\"></div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute -top-8 left-1/2 -translate-x-1/2 w-28 h-12 bg-white sticker rounded-[24px] paper-depth z-30 flex items-center justify-center p-1\" style=\"transform: rotate(-2deg);\" data-kid=\"40\">\n        <div class=\"w-full h-full bg-[#8E7993] border-2 border-dashed border-white/20 rounded-[22px] flex items-center justify-center gap-2\" data-kid=\"41\">\n           <i class=\"ti ti-moon-filled text-white text-xl drop-shadow-sm\" data-kid=\"42\"></i>\n           <div class=\"flex gap-0.5\" data-kid=\"43\">\n             <div class=\"w-1 h-1 bg-white rounded-full opacity-40\" data-kid=\"44\"></div>\n             <div class=\"w-1 h-1 bg-white rounded-full opacity-40\" data-kid=\"45\"></div>\n           </div>\n        </div>\n      </div>\n\n    </div>\n  </section>\n\n  \n  <nav class=\"absolute bottom-0 left-0 w-full h-28 scalloped-edge z-50 flex items-center justify-around px-4 pb-8\" data-kid=\"46\">\n    \n    <button class=\"group flex flex-col items-center gap-1\" data-kid=\"47\">\n      <div class=\"w-14 h-14 bg-[var(--secondary-teal)] sticker rounded-full flex items-center justify-center text-white paper-depth-sm group-hover:scale-110 group-active:scale-95\" data-kid=\"48\">\n        <i class=\"ti ti-book text-2xl\" data-kid=\"49\"></i>\n      </div>\n      <span class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-lilac)] group-hover:text-white\" data-kid=\"50\">Historias</span>\n    </button>\n    \n    \n    <button class=\"group flex flex-col items-center gap-1 -translate-y-6\" data-kid=\"51\">\n      <div class=\"w-16 h-16 bg-white border-4 border-[var(--primary-yellow)] shadow-[0px_6px_0_rgba(0,0,0,0.6)] rounded-full flex items-center justify-center text-[var(--bg-deep-plum)] paper-depth group-hover:scale-105 group-active:scale-95\" data-kid=\"52\">\n        <i class=\"ti ti-moon-filled text-3xl text-[var(--surface-eggplant)]\" data-kid=\"53\"></i>\n      </div>\n      <span class=\"text-xs font-bold uppercase tracking-wider text-white drop-shadow-md\" data-kid=\"54\">Descanso</span>\n    </button>\n    \n    \n    <button class=\"group flex flex-col items-center gap-1\" data-kid=\"55\">\n      <div class=\"w-14 h-14 bg-[var(--surface-eggplant)] sticker rounded-full border-[var(--text-lilac)]/30 flex items-center justify-center text-[var(--text-lilac)] paper-depth-sm group-hover:scale-110 group-active:scale-95\" data-kid=\"56\">\n        <i class=\"ti ti-clock text-2xl\" data-kid=\"57\"></i>\n      </div>\n      <span class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-lilac)] group-hover:text-white\" data-kid=\"58\">Rutina</span>\n    </button>\n    \n    \n    <button class=\"group flex flex-col items-center gap-1\" data-kid=\"59\">\n      <div class=\"w-14 h-14 bg-[var(--surface-eggplant)] sticker border-[var(--text-lilac)]/30 rounded-full flex items-center justify-center text-[var(--text-lilac)] paper-depth-sm group-hover:scale-110 group-active:scale-95\" data-kid=\"60\">\n        <i class=\"ti ti-music text-2xl\" data-kid=\"61\"></i>\n      </div>\n      <span class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-lilac)] group-hover:text-white\" data-kid=\"62\">Música</span>\n    </button>\n  </nav>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"63\"></script>\n<script data-kid=\"64\">\n  document.addEventListener('DOMContentLoaded', () => {\n    // Floating animations for a papercut feel\n    gsap.to('.star', {\n      opacity: 0.4,\n      duration: 1.5,\n      repeat: -1,\n      yoyo: true,\n      stagger: 0.3,\n      ease: 'sine.inOut'\n    });\n\n    gsap.to('.moon', {\n      y: -5,\n      x: 3,\n      duration: 4,\n      repeat: -1,\n      yoyo: true,\n      ease: 'sine.inOut'\n    });\n\n    gsap.to('.character-container', {\n      y: -10,\n      rotation: 1,\n      duration: 3,\n      repeat: -1,\n      yoyo: true,\n      ease: 'power1.inOut'\n    });\n\n    gsap.to('.hover-item', {\n      y: -4,\n      duration: 2.5,\n      repeat: -1,\n      yoyo: true,\n      stagger: 0.5,\n      ease: 'sine.inOut'\n    });\n\n    // Entrance animation\n    const tl = gsap.timeline();\n    tl.from('.hill-1, .hill-2', {\n      y: 100,\n      opacity: 0,\n      duration: 1,\n      stagger: 0.2,\n      ease: 'back.out(1.7)'\n    })\n    .from('.table-paper', {\n      y: 50,\n      opacity: 0,\n      duration: 0.8,\n      ease: 'back.out(1.2)'\n    }, '-=0.5')\n    .from('.titi-paper', {\n      scale: 0.5,\n      opacity: 0,\n      duration: 0.8,\n      ease: 'back.out(2)'\n    }, '-=0.3')\n    .from('nav button', {\n      y: 50,\n      opacity: 0,\n      duration: 0.5,\n      stagger: 0.1,\n      ease: 'power2.out'\n    }, '-=0.4');\n  });\n</script>\n",
